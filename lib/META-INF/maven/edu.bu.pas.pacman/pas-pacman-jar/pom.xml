<project xmlns="http://maven.apache.org/POM/4.0.0">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>edu.bu.pas.pacman</groupId>
        <artifactId>pas-pacman</artifactId>
        <version>1.0.0</version>
    </parent>

    <groupId>edu.bu.pas.pacman</groupId>
    <artifactId>pas-pacman-jar</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <name>pas-pacman-jar</name>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.release>21</maven.compiler.release>
    </properties>

    <dependencies>
        <dependency>
            <groupId>net.sourceforge.argparse4j</groupId>
            <artifactId>argparse4j</artifactId>
            <version>0.9.0</version>
            <scope>compile</scope>
        </dependency>

        <dependency>
            <groupId>junit</groupId>
            <artifactId>junit</artifactId>
            <version>4.11</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-javadoc-plugin</artifactId>
                <version>3.12.0</version>
                <executions>
                    <execution>
                        <id>mkdoc</id>
                        <phase>compile</phase>
                        <goals>
                            <goal>jar</goal>
                        </goals>
                        <!-- <configuration>
                            <reportOutputDirectory>target/javadoc</reportOutputDirectory>
                        </configuration> -->
                    </execution>
                </executions>
            </plugin>

            <!-- <plugin>
                <groupId>co.aurasphere.maven.plugins</groupId>
                <artifactId>zip-maven-plugin</artifactId>
                <version>1.0.0</version>
                <extensions>true</extensions>
                <configuration>
                    <inputDirectory>target/reports/apidocs</inputDirectory>
                    <outputDirectory>target</outputDirectory>
                    <zipName>javadoc</zipName>
                </configuration>
            </plugin> -->

            <plugin>
                <groupId>com.coderplus.maven.plugins</groupId>
                <artifactId>copy-rename-maven-plugin</artifactId>
                <version>1.0</version>
                <executions>
                    <execution>
                        <id>mk-assignment-distribution</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy</goal>
                        </goals>
                        <configuration>
                            <sourceFile>target/pas-pacman-jar-${project.version}-javadoc.jar</sourceFile>
                            <destinationFile>target/javadoc.jar</destinationFile>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>
